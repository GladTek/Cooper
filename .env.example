# MeaMart Environment Variables
# Copy this file to .env.local and fill in the actual values

# ==========================================
# REQUIRED - Google Sheets API Configuration
# ==========================================
# Get from Google Cloud Console
# https://console.cloud.google.com/
SHEETS_API_KEY=your_google_sheets_api_key_here
SHEETS_ID=your_google_sheets_spreadsheet_id_here

# ==========================================
# REQUIRED - Cloudflare Configuration
# ==========================================
# Get from Cloudflare Dashboard
# https://dash.cloudflare.com/
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# ==========================================
# REQUIRED - Webhook Security
# ==========================================
# Generate a secure random string (min 32 characters)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=your_secure_webhook_secret_here

# ==========================================
# OPTIONAL - Site Configuration
# ==========================================
# Base site URL (required for sitemap and redirects)
SITE_URL=https://meamart.com
BASE_URL=/

# ==========================================
# OPTIONAL - Deployment Configuration
# ==========================================
# Options: cloudflare, vercel, netlify, node
ADAPTER=cloudflare

# ==========================================
# OPTIONAL - Development Configuration
# ==========================================
# Set to true to enable detailed logging
DEBUG=false

# Port for local development
PORT=3000

# ==========================================
# OPTIONAL - Google OAuth Configuration
# ==========================================
# For future Google SSO implementation
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_REDIRECT_URI=https://meamart.com/auth/callback

# ==========================================
# OPTIONAL - Email Configuration
# ==========================================
# For order and review notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# NOTIFICATION_EMAIL=notifications@meamart.com

# ==========================================
# OPTIONAL - Analytics Configuration
# ==========================================
# For tracking user behavior and conversions
# ANALYTICS_ID=your_analytics_id
# EVENTS_ENDPOINT=https://api.meamart.com/events

# ==========================================
# OPTIONAL - Rate Limiting Configuration
# ==========================================
# Max webhooks per minute per IP
WEBHOOK_RATE_LIMIT=60

# Max API requests per minute per client
API_RATE_LIMIT=100
