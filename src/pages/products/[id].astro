---
/**
 * Product Detail Page
 * Displays product information, merchant details, and customer reviews
 * Generates static pages for all products from all merchant sheets
 */

import Layout from '../../layouts/Layout.astro';
import ReviewCard from '../../components/ReviewCard.astro';
import { fetchMerchantProducts, SheetsError } from '../../lib/sheets.js';

interface Product {
  id: string;
  title: string;
  description?: string;
  price: number;
  image_link?: string;
  availability: string;
  merchant_id?: string;
  merchant_name?: string;
  merchant_phone?: string;
  chat_link?: string;
  sheet_url?: string;
}

interface Merchant {
  id: string;
  name: string;
  phone: string;
  sheet_url: string;
}

interface Review {
  id: string;
  customer_name: string;
  rating: number;
  comment: string;
  created_at: string;
  verified: boolean;
}

/**
 * Generate static paths for all products
 * Fetches products from all merchants' Google Sheets
 */
export async function getStaticPaths() {
  try {
    // Get database instance
    const runtime = (globalThis as any).CLOUDFLARE_ENV;
    const db = runtime?.env?.DB;

    let merchants: Merchant[] = [];

    // Try to fetch merchants from D1, fall back to mock data
    if (db) {
      try {
        const { results } = await db.prepare(
          `SELECT id, name, phone, sheet_url 
           FROM merchants 
           WHERE active = 1 AND sheet_url IS NOT NULL`
        ).all();
        merchants = results || [];
      } catch (error) {
        console.warn('Failed to fetch merchants from D1:', error);
      }
    }

    // Fallback to mock merchants for development
    if (merchants.length === 0) {
      merchants = [
        {
          id: 'merchant_1',
          name: 'المتجر الأول',
          phone: '201001234567',
          sheet_url: process.env.PUBLIC_SAMPLE_SHEET_URL || 'https://docs.google.com/spreadsheets/d/1mHIWnDvW9cALRz8iM3K9X5P7Q2R8Z6Y4W5V3U1T2S/edit',
        }
      ];
    }

    // Fetch all products from all merchants
    const allProducts: Product[] = [];

    for (const merchant of merchants) {
      try {
        const merchantProducts = await fetchMerchantProducts(merchant.sheet_url);
        
        const enhancedProducts = merchantProducts.map((product: any) => ({
          ...product,
          merchant_id: merchant.id,
          merchant_name: merchant.name,
          merchant_phone: merchant.phone,
          sheet_url: merchant.sheet_url,
          chat_link: `https://wa.me/${merchant.phone.replace(/\D/g, '')}?text=اهتم بمنتج: ${encodeURIComponent(product.title)}`,
        }));

        allProducts.push(...enhancedProducts);
      } catch (error) {
        console.warn(`Failed to fetch products for merchant ${merchant.name}:`, error);
      }
    }

    // Generate paths for each product using unique IDs
    return allProducts.map((product) => ({
      params: { id: `${product.merchant_id}_${product.id}` },
      props: { product },
    }));
  } catch (error) {
    console.error('Error generating static paths:', error);
    return [];
  }
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
let reviews: Review[] = [];
let error: string | null = null;

// Fetch reviews from D1
try {
  const runtime = (globalThis as any).CLOUDFLARE_ENV;
  const db = runtime?.env?.DB;

  if (db && product.id && product.merchant_id) {
    const { results } = await db.prepare(
      `SELECT id, customer_name, rating, comment, created_at, verified 
       FROM reviews 
       WHERE product_id = ? AND merchant_id = ? AND is_visible = 1
       ORDER BY created_at DESC
       LIMIT 20`
    ).bind(product.id, product.merchant_id).all();

    reviews = results || [];
  }
} catch (err) {
  console.warn('Failed to fetch reviews:', err);
  error = 'Could not load reviews';
}

// Format date for display
function formatDate(dateString: string): string {
  try {
    const date = new Date(dateString);
    return date.toLocaleDateString('ar-EG', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    });
  } catch {
    return dateString;
  }
}

// Calculate average rating
const averageRating = reviews.length > 0
  ? (reviews.reduce((sum, r) => sum + r.rating, 0) / reviews.length).toFixed(1)
  : 0;

// Detect RTL language
const lang = Astro.currentLocale || 'en';
const isRTL = lang === 'ar';

// Generate JSON-LD schema
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.title,
  description: product.description || '',
  image: product.image_link || '',
  offers: {
    '@type': 'Offer',
    price: product.price.toString(),
    priceCurrency: 'EGP',
    availability: product.availability === 'available' ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
  },
  brand: {
    '@type': 'Brand',
    name: product.merchant_name || '',
  },
  aggregateRating: reviews.length > 0 ? {
    '@type': 'AggregateRating',
    ratingValue: averageRating,
    reviewCount: reviews.length,
  } : undefined,
  review: reviews.slice(0, 5).map((review) => ({
    '@type': 'Review',
    author: {
      '@type': 'Person',
      name: review.customer_name,
    },
    reviewRating: {
      '@type': 'Rating',
      ratingValue: review.rating,
    },
    reviewBody: review.comment,
    datePublished: review.created_at,
  })),
};
---

<Layout title={`${product.title} - MeaMart`}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  
  <div class="min-h-screen bg-gray-50" dir={isRTL ? 'rtl' : 'ltr'}>
    {/* Product Header */}
    <div class="bg-white shadow-sm">
      <div class="max-w-4xl mx-auto px-4 py-6 sm:px-6 lg:px-8">
        <div class="flex items-center gap-2 text-sm text-gray-600 mb-4">
          <a href="/feed" class="hover:text-blue-600">
            {isRTL ? 'المتجر' : 'Store'}
          </a>
          <span>/</span>
          <span>{product.merchant_name}</span>
          <span>/</span>
          <span class="text-gray-900 font-semibold">{product.title}</span>
        </div>
      </div>
    </div>

    {/* Main Content */}
    <div class="max-w-4xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        {/* Product Image */}
        <div class="flex items-center justify-center">
          {product.image_link ? (
            <img
              src={product.image_link}
              alt={product.title}
              class="w-full h-auto rounded-lg shadow-lg object-cover aspect-[3/4]"
            />
          ) : (
            <div class="w-full aspect-[3/4] bg-gray-200 rounded-lg flex items-center justify-center">
              <svg
                class="w-16 h-16 text-gray-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                />
              </svg>
            </div>
          )}
        </div>

        {/* Product Details */}
        <div class="flex flex-col justify-between">
          <div>
            {/* Title and Price */}
            <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">
              {product.title}
            </h1>

            {/* Rating */}
            {reviews.length > 0 && (
              <div class="flex items-center gap-2 mb-4">
                <div class="flex gap-1">
                  {[...Array(5)].map((_, i) => (
                    <svg
                      key={i}
                      class={`w-5 h-5 ${
                        i < Math.round(Number(averageRating))
                          ? 'text-yellow-400 fill-current'
                          : 'text-gray-300'
                      }`}
                      viewBox="0 0 20 20"
                    >
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
                <span class="text-sm text-gray-600">
                  {averageRating} ({reviews.length} {isRTL ? 'تقييم' : 'reviews'})
                </span>
              </div>
            )}

            {/* Price */}
            <div class="mb-6">
              <p class="text-4xl font-bold text-blue-600 mb-2">
                {Math.floor(product.price)} {isRTL ? 'ج.م' : 'EGP'}
              </p>
              <p class={`text-sm font-semibold ${
                product.availability === 'available'
                  ? 'text-green-600'
                  : 'text-red-600'
              }`}>
                {product.availability === 'available'
                  ? isRTL ? 'متاح' : 'In Stock'
                  : isRTL ? 'غير متاح' : 'Out of Stock'}
              </p>
            </div>

            {/* Description */}
            {product.description && (
              <div class="mb-6">
                <h2 class="text-lg font-semibold text-gray-900 mb-2">
                  {isRTL ? 'الوصف' : 'Description'}
                </h2>
                <p class="text-gray-600 leading-relaxed">
                  {product.description}
                </p>
              </div>
            )}
          </div>

          {/* Merchant Info */}
          <div class="bg-gray-50 rounded-lg p-4 mb-6">
            <div class="flex items-center justify-between mb-4">
              <div>
                <p class="text-sm text-gray-600">
                  {isRTL ? 'البائع' : 'Seller'}
                </p>
                <p class="font-semibold text-gray-900">
                  {product.merchant_name || 'Unknown'}
                </p>
              </div>
              <svg
                class="w-6 h-6 text-blue-600"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"
                />
              </svg>
            </div>

            {/* Contact Buttons */}
            <div class="flex gap-3">
              <a
                href={product.chat_link}
                target="_blank"
                rel="noopener noreferrer"
                class="flex-1 bg-green-500 hover:bg-green-600 text-white font-semibold py-3 rounded-lg flex items-center justify-center gap-2 transition-colors"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421-7.403h-.004c-1.025 0-2.04-.315-2.918-.916l-.209-.124-2.16.413.421-2.054c-.57-.903-.898-1.955-.898-3.035 0-3.181 2.587-5.768 5.768-5.768 1.542 0 2.992.601 4.082 1.691 1.089 1.09 1.692 2.539 1.692 4.082 0 3.181-2.587 5.768-5.768 5.768m4.989-14.411C6.463.98 3.606 1.05 1.635 2.888c-1.97 1.839-2.063 4.949-.208 6.884l.041.046-1.365 4.177 4.304-1.33.06.033c1.926 1.879 5.03 1.787 6.884-.208 1.839-1.97 1.949-5.111.208-7.084-.438-.462-.956-.851-1.529-1.126" />
                </svg>
                {isRTL ? 'راسل' : 'Chat'}
              </a>

              <a
                href={`tel:${product.merchant_phone?.replace(/\D/g, '')}`}
                class="flex-1 border-2 border-blue-600 text-blue-600 hover:bg-blue-50 font-semibold py-3 rounded-lg flex items-center justify-center gap-2 transition-colors"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773c.058.319.255.684.481.95.226.266.603.554.988.667.385.113.799.02 1.18-.122l2.75-1.1a1 1 0 011.23.754l.74 4.435a1 1 0 01-.543 1.06l-2.08 1.04a1 1 0 00-.523 1.23c1.07 3.741 3.704 6.374 7.445 7.445a1 1 0 001.23-.523l1.04-2.08a1 1 0 011.06-.543l4.435.74a1 1 0 01.836.986v2.153a1 1 0 01-1 1h-2C7.82 20 2 14.18 2 7V3z" />
                </svg>
                {isRTL ? 'اتصل' : 'Call'}
              </a>
            </div>
          </div>
        </div>
      </div>

      {/* Reviews Section */}
      <div class="bg-white rounded-lg shadow-sm p-6 md:p-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">
          {isRTL ? 'التقييمات' : 'Reviews'}
        </h2>

        {error && (
          <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm">
            {error}
          </div>
        )}

        {reviews.length > 0 ? (
          <div class="space-y-6">
            {reviews.map((review) => (
              <ReviewCard
                key={review.id}
                review={{
                  customer_name: review.customer_name,
                  rating: review.rating,
                  comment: review.comment,
                  created_at: review.created_at,
                }}
              />
            ))}
          </div>
        ) : (
          <div class="text-center py-12">
            <svg
              class="w-12 h-12 text-gray-400 mx-auto mb-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"
              />
            </svg>
            <p class="text-gray-600">
              {isRTL ? 'لا توجد تقييمات بعد. كن أول من يقيّم!' : 'No reviews yet. Be the first to review!'}
            </p>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>

<style is:global>
/* Smooth scrolling */
html {
  scroll-behavior: smooth;
}

/* Image optimization */
img {
  max-width: 100%;
  height: auto;
  display: block;
}
</style>
